# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public URL of this app (no trailing slash)
BETTER_AUTH_URL=http://localhost:3000
# Optional: extra origins for CSRF/cookies (comma-separated)
# BETTER_AUTH_TRUSTED_ORIGINS=https://your-app.example.com

# Keycloak OIDC — issuer must include realm, e.g. https://keycloak.kshrd.app/realms/my-realm
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ISSUER=https://keycloak.kshrd.app/realms/YOUR_REALM

# In Keycloak, set Valid redirect URIs to:
#   {BETTER_AUTH_URL}/api/auth/oauth2/callback/keycloak
# Web origins: your app origin (e.g. http://localhost:3000)
